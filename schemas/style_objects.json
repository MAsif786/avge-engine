{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/style_objects/v1.json",
  "title": "style_objects",
  "description": "Update the visual style of one or more existing elements. Only provided fields are changed; omitted fields are left untouched.",
  "type": "object",
  "properties": {
    "ids": {
      "type": ["array", "null"],
      "description": "Element IDs to restyle.",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 200
    },
    "selector": {
      "$ref": "https://avge.dev/schemas/_defs/v1.json#/$defs/selector"
    },
    "fill": {
      "$ref": "https://avge.dev/schemas/_defs/v1.json#/$defs/color",
      "description": "Fill color as hex string, or null for no fill."
    },
    "stroke": {
      "$ref": "https://avge.dev/schemas/_defs/v1.json#/$defs/color",
      "description": "Stroke color as hex string, or null for no stroke."
    },
    "stroke_width": {
      "$ref": "https://avge.dev/schemas/_defs/v1.json#/$defs/stroke_width"
    },
    "opacity": {
      "type": "number",
      "description": "Object opacity 0.0–1.0.",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "material": {
      "type": "string",
      "description": "Built-in material preset. Applies base style and optional generated detail overlays.",
      "enum": ["glass", "brushed_metal", "concrete", "wood", "tile", "foliage"]
    },
    "material_detail": {
      "type": "boolean",
      "description": "When material is provided, generate editable highlight/shadow/texture detail elements.",
      "default": true
    },
    "material_intensity": {
      "type": "number",
      "description": "Generated material detail strength.",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.65
    }
  },
  "additionalProperties": false,
  "oneOf": [
    { "required": ["ids"] },
    { "required": ["selector"] }
  ],
  "anyOf": [
    { "required": ["fill"] },
    { "required": ["stroke"] },
    { "required": ["stroke_width"] },
    { "required": ["opacity"] },
    { "required": ["material"] }
  ]
}

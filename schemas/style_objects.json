{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/style_objects/v1.json",
  "title": "style_objects",
  "description": "Update the visual style of one or more existing regions. Only provided fields are changed; omitted fields are left untouched.",
  "type": "object",
  "properties": {
    "ids": {
      "type": "array",
      "description": "Region IDs to restyle.",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 200
    },
    "fill": {
      "oneOf": [
        { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        { "type": "null" }
      ],
      "description": "Fill color as hex string, or null for no fill."
    },
    "stroke": {
      "oneOf": [
        { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        { "type": "null" }
      ],
      "description": "Stroke color as hex string, or null for no stroke."
    },
    "stroke_width": {
      "type": ["number", "null"],
      "description": "Stroke width in canvas pixels.",
      "minimum": 0.0,
      "maximum": 512
    },
    "opacity": {
      "type": "number",
      "description": "Object opacity 0.0–1.0.",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "material": {
      "type": "string",
      "description": "Built-in material preset. Applies base style and optional generated detail overlays.",
      "enum": ["glass", "brushed_metal", "concrete", "wood", "tile", "foliage"]
    },
    "material_detail": {
      "type": "boolean",
      "description": "When material is provided, generate editable highlight/shadow/texture detail regions.",
      "default": true
    },
    "material_intensity": {
      "type": "number",
      "description": "Generated material detail strength.",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.65
    }
  },
  "required": ["ids"],
  "additionalProperties": false,
  "anyOf": [
    { "required": ["fill"] },
    { "required": ["stroke"] },
    { "required": ["stroke_width"] },
    { "required": ["opacity"] },
    { "required": ["material"] }
  ]
}

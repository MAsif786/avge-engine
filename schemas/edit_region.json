{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "edit_region",
  "description": "Modify an existing region's outline, smoothness, style, or z_index. Only provided fields change.",
  "type": "object",
  "properties": {
    "region_id": {"type": "string"},
    "document_id": {"type": "string"},
    "outline": {"type": "array", "items": {"type": "array", "prefixItems": [{"type": "number"}, {"type": "number"}]}},
    "smoothness": {"type": "number", "minimum": 0, "maximum": 1},
    "fill": {"type": "string"},
    "stroke": {"type": "string"},
    "stroke_width": {
      "type": ["number", "null"],
      "description": "Stroke width in canvas pixels.",
      "minimum": 0,
      "maximum": 512
    },
    "opacity": {"type": "number", "minimum": 0, "maximum": 1},
    "z_index": {"type": "integer"},
    "layer": {"type": "string"}
  },
  "required": ["region_id"]
}

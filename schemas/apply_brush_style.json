{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/apply_brush_style/v1.json",
  "title": "apply_brush_style",
  "description": "Apply a digital art brush preset to existing regions while keeping output editable vector art.",
  "type": "object",
  "properties": {
    "selector": {
      "$ref": "https://avge.dev/schemas/_defs/v1.json#/$defs/selector"
    },
    "brush": {
      "type": "string",
      "enum": ["pencil", "ink", "g_pen", "mapping_pen", "flat", "round", "airbrush", "soft", "hard", "watercolor", "gouache", "oil", "chalk", "texture", "hair", "grass_leaf", "cloud", "particle_fx"],
      "default": "ink"
    },
    "document_id": { "type": ["string", "null"] },
    "color": {
      "$ref": "https://avge.dev/schemas/_defs/v1.json#/$defs/color",
      "description": "Override brush color."
    },
    "size": {
      "type": ["number", "null"],
      "description": "Override brush stroke width in canvas pixels.",
      "minimum": 0,
      "maximum": 512
    },
    "opacity": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "apply_to": { "type": "string", "enum": ["stroke", "fill", "both"], "default": "stroke" },
    "blend_mode": {
      "$ref": "https://avge.dev/schemas/_defs/v1.json#/$defs/blend_mode"
    },
    "pressure": { "type": ["boolean", "null"] },
    "texture_strength": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 }
  },
  "additionalProperties": false
}

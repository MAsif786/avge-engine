{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/edit_regions/v1.json",
  "title": "edit_regions",
  "description": "Edit multiple regions with per-item content/style updates. Use transform_objects for move/scale/rotate/mirror/align.",
  "type": "object",
  "properties": {
    "document_id": {"type": ["string", "null"]},
    "updates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "outline": {
            "type": ["array", "null"],
            "items": {"type": "array", "prefixItems": [{"type": "number"}, {"type": "number"}], "minItems": 2, "maxItems": 2},
            "minItems": 2
          },
          "point_index": {"type": ["integer", "null"], "minimum": 0},
          "point_coords": {
            "type": ["array", "null"],
            "prefixItems": [{"type": "number"}, {"type": "number"}],
            "minItems": 2,
            "maxItems": 2
          },
          "point_dx": {"type": ["number", "null"]},
          "point_dy": {"type": ["number", "null"]},
          "fill": {"type": ["string", "null"]},
          "stroke": {"type": ["string", "null"]},
          "stroke_width": {
            "type": ["number", "null"],
            "description": "Stroke width in canvas pixels.",
            "minimum": 0,
            "maximum": 512
          },
          "opacity": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
          "z_index": {"type": ["integer", "null"]},
          "layer": {"type": ["string", "null"]},
          "blend_mode": {
            "type": ["string", "null"],
            "enum": ["normal", "multiply", "screen", "overlay", "darken", "lighten", "color-dodge", "linear-dodge", "color-burn", "soft-light", "hard-light", "difference", "hue", "saturation", "color", "luminosity", "add", null]
          },
          "clip_to": {"type": ["string", "null"]},
          "stroke_linecap": {"type": ["string", "null"], "enum": ["butt", "round", "square", null]},
          "stroke_dasharray": {"type": ["string", "null"]}
        },
        "required": ["id"],
        "additionalProperties": false
      }
    }
  },
  "required": ["updates"],
  "additionalProperties": false
}

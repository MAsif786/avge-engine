{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/create_ellipse_band/v1.json",
  "title": "create_ellipse_band",
  "description": "Create a filled elliptical ring or partial arc band for circular balconies, overhead rings, rail strips, counters, rims, and curved floors.",
  "type": "object",
  "properties": {
    "cx": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "cy": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "rx": { "type": "number", "exclusiveMinimum": 0.0, "maximum": 1.5 },
    "ry": { "type": ["number", "null"], "exclusiveMinimum": 0.0, "maximum": 1.5, "default": null },
    "thickness": { "type": ["number", "null"], "exclusiveMinimum": 0.0, "maximum": 1.0, "default": 0.03 },
    "inner_rx": { "type": ["number", "null"], "exclusiveMinimum": 0.0, "maximum": 1.5, "default": null },
    "inner_ry": { "type": ["number", "null"], "exclusiveMinimum": 0.0, "maximum": 1.5, "default": null },
    "start_angle": { "type": "number", "default": 0.0 },
    "end_angle": { "type": "number", "default": 360.0 },
    "rotation": { "type": "number", "default": 0.0 },
    "samples": { "type": "integer", "minimum": 4, "maximum": 180, "default": 64 },
    "perspective": { "type": "number", "minimum": -0.75, "maximum": 0.75, "default": 0.0 },
    "skew_x": { "type": "number", "minimum": -2.0, "maximum": 2.0, "default": 0.0 },
    "region_id": {
      "type": "string",
      "description": "Optional unique ID (auto-generated if omitted).",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]{0,63}$"
    },
    "document_id": { "type": ["string", "null"], "default": null },
    "layer": { "type": "string", "default": "default", "maxLength": 64 },
    "fill": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ],
      "default": "#CCCCCC"
    },
    "stroke": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ],
      "default": "#333333"
    },
    "stroke_width": { "type": "number", "minimum": 0.0, "maximum": 0.1, "default": 0.005 },
    "stroke_width_px": {
      "type": ["number", "null"],
      "description": "Stroke width in canvas pixels. Overrides stroke_width when provided.",
      "minimum": 0.0,
      "maximum": 512,
      "default": null
    },
    "opacity": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 1.0 },
    "fill_gradient": { "type": ["object", "string", "null"], "default": null },
    "smoothness": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.0 },
    "z_index": { "type": "integer", "default": 0 },
    "z_before": { "type": ["string", "null"], "default": null },
    "z_after": { "type": ["string", "null"], "default": null },
    "clip_to": { "type": ["string", "null"], "default": null },
    "blend_mode": {
      "type": ["string", "null"],
      "enum": ["normal", "multiply", "screen", "overlay", "darken", "lighten", "color-dodge", "color-burn", "soft-light", "hard-light", null],
      "default": null
    },
    "tags": { "type": ["object", "null"], "default": null },
    "groups": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "default": null
    }
  },
  "required": ["cx", "cy", "rx"],
  "additionalProperties": false
}

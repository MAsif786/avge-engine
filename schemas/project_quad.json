{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/project_quad/v1.json",
  "title": "project_quad",
  "description": "Create or perspective-warp a rectangular/panel region into a target quadrilateral. Use for tables, windows, wall panels, floor tiles, screens, and signs.",
  "type": "object",
  "properties": {
    "target_quad": {
      "type": "array",
      "description": "Four normalized points in order: top-left, top-right, bottom-right, bottom-left.",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "array",
        "prefixItems": [
          { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        ],
        "minItems": 2,
        "maxItems": 2
      }
    },
    "document_id": { "type": ["string", "null"], "default": null },
    "region_id": {
      "type": ["string", "null"],
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]{0,63}$",
      "default": null
    },
    "source_region_id": {
      "type": ["string", "null"],
      "description": "Existing region to warp. Omit to create a new projected panel.",
      "default": null
    },
    "replace_source": { "type": "boolean", "default": false },
    "columns": { "type": "integer", "minimum": 1, "maximum": 64, "default": 1 },
    "rows": { "type": "integer", "minimum": 1, "maximum": 64, "default": 1 },
    "layer": { "type": "string", "default": "default", "maxLength": 64 },
    "z_index": { "type": "integer", "default": 0 },
    "fill": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ],
      "default": "#CCCCCC"
    },
    "stroke": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ],
      "default": "#333333"
    },
    "stroke_width": { "type": ["number", "null"], "minimum": 0.0, "maximum": 0.1, "default": 0.005 },
    "stroke_width_px": {
      "type": ["number", "null"],
      "description": "Stroke width in canvas pixels. Overrides stroke_width when provided.",
      "minimum": 0.0,
      "maximum": 512,
      "default": null
    },
    "opacity": { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0, "default": 1.0 },
    "blend_mode": {
      "type": ["string", "null"],
      "enum": ["normal", "multiply", "screen", "overlay", "darken", "lighten", "color-dodge", "color-burn", "soft-light", "hard-light", null],
      "default": null
    },
    "smoothness": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.0 },
    "group_name": { "type": ["string", "null"], "default": null },
    "inherit_style": { "type": "boolean", "default": false }
  },
  "required": ["target_quad"],
  "additionalProperties": false
}

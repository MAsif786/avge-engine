{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/create_shadow/v1.json",
  "title": "create_shadow",
  "description": "Create a soft offset shadow from a region outline. Omit onto_region_id for a grounding/depth shadow, or provide onto_region_id to clip the shadow onto a receiver region.",
  "type": "object",
  "properties": {
    "region_id": {
      "type": "string",
      "description": "Source region ID."
    },
    "onto_region_id": {
      "type": ["string", "null"],
      "description": "Optional receiver region. When set, the shadow is clipped to this region and layered relative to it."
    },
    "document_id": {
      "type": ["string", "null"],
      "description": "Document UUID. Omit/null to use the active document."
    },
    "direction": {
      "type": "number",
      "description": "Shadow offset angle in degrees. 0=right, 90=down.",
      "default": 45.0
    },
    "distance": {
      "type": "number",
      "description": "Shadow offset distance in normalized canvas units.",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.03
    },
    "softness": {
      "type": "number",
      "description": "Gaussian blur radius in pixels.",
      "minimum": 0.0,
      "maximum": 64.0,
      "default": 4.0
    },
    "opacity": {
      "type": "number",
      "description": "Shadow opacity.",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.22
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "default": "#000000"
    },
    "scale": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 10.0,
      "default": 1.0
    },
    "sx": {
      "type": ["number", "null"],
      "minimum": 0.01,
      "maximum": 10.0
    },
    "sy": {
      "type": ["number", "null"],
      "minimum": 0.01,
      "maximum": 10.0
    },
    "z_offset": {
      "type": ["integer", "null"],
      "description": "Relative z-index. Defaults to -1 for grounding shadows and +1 for clipped shadows."
    },
    "new_region_id": {
      "type": ["string", "null"],
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]{0,63}$"
    }
  },
  "required": ["region_id"],
  "additionalProperties": false
}

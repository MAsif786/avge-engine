{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/create_element/v1.json",
  "title": "create_element",
  "description": "Create a vector element from a coarse point outline. The engine fits smooth Bézier curves to the outline using the supplied geometric constraints.",
  "type": "object",
  "properties": {
    "outline": {
      "type": ["array", "null"],
      "description": "Point coordinate pairs in normalized space (0.0–1.0). Keep to 3–30 points for best quality.",
      "items": {
        "type": "array",
        "prefixItems": [
          { "type": "number", "minimum": 0.0, "maximum": 1.0, "description": "x-coordinate" },
          { "type": "number", "minimum": 0.0, "maximum": 1.0, "description": "y-coordinate" }
        ],
        "minItems": 2,
        "maxItems": 2000
      },
      "minItems": 2
    },
    "element_id": {
      "type": "string",
      "description": "Optional unique ID (auto-generated if omitted).",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]{0,63}$"
    },
    "layer": {
      "type": "string",
      "description": "Layer name for organization.",
      "default": "default",
      "maxLength": 64
    },
    "type": {
      "type": "string",
      "description": "Object type discriminator.",
      "default": "element",
      "enum": ["element"]
    },
    "closed": {
      "type": "boolean",
      "description": "Whether the outline forms a closed loop (last point connects to first).",
      "default": true
    },
    "smoothness": {
      "type": "number",
      "description": "Curve smoothness 0.0–1.0. 0.0 = sharp/polygonal, 0.2–0.5 = mixed rigid/organic, 0.6–0.8 = organic/curved, 1.0 = very loose. See §4.5d for per-category guidance.",
      "default": 0.5,
      "minimum": 0.0,
      "maximum": 1.0
    },
    "corner_style": {
      "type": "string",
      "description": "Corner treatment.",
      "default": "round",
      "enum": ["round", "sharp", "bevel"]
    },
    "fill": {
      "oneOf": [
        { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        { "type": "null" }
      ],
      "description": "Fill color as hex string, or null/omitted for no fill.",
      "default": "#CCCCCC"
    },
    "stroke": {
      "oneOf": [
        { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        { "type": "null" }
      ],
      "description": "Stroke color as hex string, or null/omitted for no stroke.",
      "default": "#333333"
    },
    "stroke_width": {
      "type": ["number", "null"],
      "description": "Stroke width in canvas pixels.",
      "minimum": 0.0,
      "maximum": 512,
      "default": null
    },
    "opacity": {
      "type": "number",
      "description": "Object opacity 0.0–1.0.",
      "default": 1.0,
      "minimum": 0.0,
      "maximum": 1.0
    },
    "shape": {
      "type": ["object", "null"],
      "description": "Optional primitive shape. Supported types include rect, ellipse, line, polyline, compound_path, arc, polygon, and star.",
      "additionalProperties": true,
      "default": null
    },
    "outline_pattern": {
      "type": ["string", "null"],
      "description": "Optional generated outline style for primitive shapes.",
      "enum": ["dashed", "dotted", "wavy", "zigzag", "rough", "sketch", "tapered", "pressure", null],
      "default": null
    },
    "fill_pattern": {
      "type": ["string", "null"],
      "description": "Optional generated interior texture clipped to the primitive shape.",
      "enum": ["hatch", "cross_hatch", "contour_hatch", "scribble", "stipple", null],
      "default": null
    },
    "pattern_density": {
      "type": "integer",
      "description": "Density/count for generated outline or fill pattern overlays.",
      "minimum": 1,
      "maximum": 600,
      "default": 12
    },
    "pattern_amplitude": {
      "type": "number",
      "description": "Wave/zigzag/contour amplitude in normalized units.",
      "minimum": 0.0,
      "maximum": 0.5,
      "default": 0.02
    },
    "pattern_jitter": {
      "type": "number",
      "description": "Random variation in normalized units for rough/sketch/scribble effects.",
      "minimum": 0.0,
      "maximum": 0.25,
      "default": 0.0
    },
    "pattern_seed": {
      "type": "integer",
      "description": "Deterministic seed for generated pattern variation.",
      "default": 1
    },
    "pattern_stroke_width": {
      "type": ["number", "null"],
      "description": "Pattern overlay stroke width in canvas pixels.",
      "minimum": 0.0,
      "maximum": 512,
      "default": null
    },
    "pattern_opacity": {
      "type": ["number", "null"],
      "description": "Pattern overlay opacity.",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": null
    },
    "metadata_tags": {
      "type": "array",
      "description": "Optional semantic tags (stored as opaque strings — engine never interprets).",
      "items": { "type": "string", "maxLength": 64 },
      "maxItems": 32
    }
  },
  "anyOf": [
    { "required": ["outline"] },
    { "required": ["shape"] }
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avge.dev/schemas/add_depth_shadow/v1.json",
  "title": "add_depth_shadow",
  "description": "Create a soft offset shadow from a region outline.",
  "type": "object",
  "properties": {
    "region_id": {
      "type": "string",
      "description": "Source region ID."
    },
    "document_id": {
      "type": ["string", "null"],
      "description": "Document UUID. Omit/null to use the active document."
    },
    "direction": {
      "type": "number",
      "description": "Shadow offset angle in degrees. 0=right, 90=down.",
      "default": 45.0
    },
    "distance": {
      "type": "number",
      "description": "Shadow offset distance in normalized canvas units.",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.03
    },
    "softness": {
      "type": "number",
      "description": "Gaussian blur radius in pixels.",
      "minimum": 0.0,
      "maximum": 64.0,
      "default": 4.0
    },
    "opacity": {
      "type": "number",
      "description": "Shadow opacity.",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.22
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "default": "#000000"
    },
    "scale": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 10.0,
      "default": 1.0
    },
    "sx": {
      "type": ["number", "null"],
      "minimum": 0.01,
      "maximum": 10.0
    },
    "sy": {
      "type": ["number", "null"],
      "minimum": 0.01,
      "maximum": 10.0
    },
    "z_offset": {
      "type": "integer",
      "default": -1
    },
    "new_region_id": {
      "type": ["string", "null"],
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]{0,63}$"
    }
  },
  "required": ["region_id"],
  "additionalProperties": false
}
